# Django settings
DJANGO_SECRET_KEY=django-insecure-dev-only-change-in-production
DJANGO_DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# MySQL settings
MAJORA_MYSQL_HOST=mysql
MAJORA_MYSQL_PORT=3306
MAJORA_MYSQL_USER=majora
MAJORA_MYSQL_PASSWORD=majora
MAJORA_MYSQL_NAME=majora

# Email settings
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_EMAIL_HOST=localhost
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=true
DJANGO_DEFAULT_FROM_EMAIL=no-reply@majora.local

# Frontend settings
FRONTEND_DEV_MODE=true

# Cache warmer (Navi)
MAJORA_PRODUCTION_URL=http://localhost:3000
